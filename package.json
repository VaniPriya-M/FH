{
  "name": "funh-appointment-booking-tests",
  "version": "1.0.0",
  "description": "Playwright testing framework for appointment booking system with sign-in flow and payment",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:e2e": "npx playwright test tests/e2e/",
